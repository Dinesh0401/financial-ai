APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_PER_MINUTE=100
REQUEST_TIMEOUT_SECONDS=15
FINNA_OCR_BACKEND=auto
# Optional when tesseract is not on PATH:
# FINNA_TESSERACT_CMD=/usr/bin/tesseract

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your_publishable_key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_secret_key

DATABASE_RUNTIME_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/finna
DATABASE_MIGRATION_URL=postgresql+psycopg://postgres:postgres@postgres:5432/finna

TEST_DATABASE_RUNTIME_URL=postgresql+asyncpg://postgres:postgres@localhost:54329/finna_test
TEST_DATABASE_MIGRATION_URL=postgresql+psycopg://postgres:postgres@localhost:54329/finna_test

GEMINI_API_KEY=your_gemini_api_key

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_publishable_key
